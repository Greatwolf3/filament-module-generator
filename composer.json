{
    "name":  "greatwolf3/filament-module-generator",
    "version":  "v4.0.7",
    "description":  "Filament 5 plugin for generating Laravel modules with nwidart/laravel-modules integration",
    "keywords":  [
                     "laravel",
                     "filament",
                     "modules",
                     "nwidart",
                     "generator",
                     "plugin"
                 ],
    "homepage":  "https://github.com/Greatwolf3/filament-module-generator",
    "license":  "MIT",
    "authors":  [
                    {
                        "name":  "Greatwolf",
                        "email":  "bruno.guerzoni@gmail.com"
                    }
                ],
    "require":  {
                    "php":  "^8.3",
                    "filament/filament":  "^5.0",
                    "illuminate/console":  "^13.0",
                    "illuminate/support":  "^13.0",
                    "nwidart/laravel-modules":  "^13.0",
                    "wikimedia/composer-merge-plugin":  "^2.1"
                },
    "require-dev":  {
                        "orchestra/testbench":  "^11.0",
                        "phpunit/phpunit":  "^11.0 || ^12.0"
                    },
    "autoload":  {
                     "psr-4":  {
                                   "Greatwolf\\FilamentModuleGenerator\\":  "src/"
                               }
                 },
    "autoload-dev":  {
                         "psr-4":  {
                                       "Greatwolf\\FilamentModuleGenerator\\Tests\\":  "tests/"
                                   }
                     },
    "extra":  {
                  "laravel":  {
                                  "providers":  [
                                                    "Greatwolf\\FilamentModuleGenerator\\FilamentModuleGeneratorServiceProvider"
                                                ]
                              }
              },
    "scripts":  {
                    "test":  "vendor/bin/phpunit",
                    "test-coverage":  "vendor/bin/phpunit --coverage-html coverage",
                    "pre-package-uninstall":  [
                                                  "Greatwolf\\FilamentModuleGenerator\\Composer\\CleanupPanelProviders::prePackageUninstall"
                                              ]
                },
    "config":  {
                   "sort-packages":  true,
                   "optimize-autoloader":  true
               },
    "minimum-stability":  "stable",
    "prefer-stable":  true
}
